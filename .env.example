# Generate a high-entropy value locally. Never commit a real application secret.
APP_SECRET=replace-with-a-secure-random-value

# Optional for the no-key fallback; required to activate live Clerk widgets.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Browser-reachable gateway origin used by standalone frontend zones for auth redirects.
GATEWAY_PUBLIC_ORIGIN=http://localhost:3000

# Docker defaults to the local Supabase database on host port 54322.
# Override this for a hosted or separately managed PostgreSQL instance.
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?sslmode=disable
